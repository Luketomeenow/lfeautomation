# Google Service Account (from the downloaded JSON key)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n

# Server
PORT=3000
POLL_INTERVAL_MS=60000

# Google Spreadsheet IDs (from each form's linked sheet URL)
SHEET_SETTER_EOD=
SHEET_CLOSER_EOD=
SHEET_POST_CALL=
SHEET_COMPANY_EOD=
SHEET_SALES_EOD=
SHEET_AD_REPORTS=
SHEET_BOOKED_CALL=

# Discord Webhook URLs (one per target channel)
DISCORD_WEBHOOK_DAILY_REPORTS=
DISCORD_WEBHOOK_CALL_NOTES=
DISCORD_WEBHOOK_AD_REPORTS=
DISCORD_WEBHOOK_BOOKED_CALL=
DISCORD_WEBHOOK_NEW_LEAD=
DISCORD_WEBHOOK_NO_SHOW=
DISCORD_WEBHOOK_FOLLOW_UP=
DISCORD_WEBHOOK_CLOSED_DEAL=

# GoHighLevel — location ID for contact links in pipeline embeds (no-show / follow-up / closed-deal)
# Find in GHL URL when you open your location: .../location/THIS_PART/...
# GHL_LOCATION_ID=
DISCORD_WEBHOOK_WHOP=
DISCORD_WEBHOOK_NEW_PAYMENTS=
DISCORD_WEBHOOK_FAILED_PAYMENTS=
DISCORD_WEBHOOK_FANBASIS=

# FanBasis — webhook POST to /fanbasis/webhook; secret from FanBasis when you create the subscription
# FANBASIS_WEBHOOK_SECRET=

# Stripe (for #new-payments channel)
# STRIPE_WEBHOOK_SECRET=whsec_... (from Stripe Dashboard → Developers → Webhooks → Signing secret)
# STRIPE_SECRET_KEY=sk_... (optional; only needed for signature verification)
# Successful payments at or below this amount (cents) also post to DISCORD_WEBHOOK_NEW_LEAD (#new-lead). Default 5000 = $50.00 ($27 qualifies)
# STRIPE_LOW_TICKET_MAX_CENTS=5000

# Revenue sheet (LFE Business Worksheet) – Whop & Stripe append rows here (same GOOGLE_* as form polling)
# Share the spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as Editor, or appends return 403.
# Tab name must match exactly (e.g. Revenue). Test: GET https://your-host/revenue/test
REVENUE_SHEET_ID=
REVENUE_SHEET_NAME=Revenue

# Optional: persistent state directory (Railway volume mount path)
# STATE_DIR=/data
